<mujoco model="vention">
  <option integrator="implicitfast"/>

  <compiler angle="radian" meshdir="assets"/>

  <!-- Default camera: front view looking at workspace -->
  <statistic center="0 -0.4 1.1" extent="1.5"/>
  <visual>
    <global azimuth="-90" elevation="-25"/>
    <!-- Glossy "movie robot" lighting: soft ambient + specular highlights -->
    <headlight ambient="0.4 0.4 0.4" diffuse="0.4 0.4 0.4" specular="0.3 0.3 0.3"/>
  </visual>

  <contact>
    <exclude body1="vention_base" body2="left_arm_vention_base"/>
    <exclude body1="vention_base" body2="right_arm_vention_base"/>
  </contact>

  <default>
    <default class="vention">
      <!-- Anodized aluminum frame appearance -->
      <material specular="0.6" shininess="0.3"/>
      <default class="visual">
        <geom type="mesh" group="2" contype="0" conaffinity="0"/>
      </default>
      <default class="collision">
        <geom type="mesh" group="3" rgba="0.7 0.7 0.7 0.9"/>
      </default>
    </default>
  </default>

  <asset>
    <!-- Light gray skybox for paper-quality screenshots (toggle skybox in viewer Rendering menu) -->
    <texture name="light_skybox" type="skybox" builtin="flat" rgb1="0.92 0.92 0.92" width="1" height="1"/>
    <!-- Dark anodized blue for Vention frame and mounting plates -->
    <material name="blue" rgba="0.12 0.18 0.38 1" specular="0.5" shininess="0.3"/>
    <material name="red" rgba="0.12 0.18 0.38 1" specular="0.5" shininess="0.3"/>

    <mesh file="vention_frame_visual_model.stl"/>
  </asset>

  <worldbody>
    <body name="vention_base" childclass="vention">
      <geom mesh="vention_frame_visual_model" material="blue" class="visual"/>

      <!-- Exact dimensions of the vention table are: x: 1.26, y: 1.12, z: 0.755 -->
      <!-- To add padding to the Vention table, increase the z-direction offset -->
      <geom type="box" pos="0 -0.475 0.3825" size="0.65 0.6 0.371" class="collision"/>
      <!-- Vention actuator frame back panel - contact exclusion prevents arm base collision -->
      <geom name="vention_back_panel" type="box" pos="0 -0.96 1.41" size="0.55 0.1 0.66" class="collision"/>

      <!-- Collision for side box -->
      <geom name="box" class="collision" type="box" size="0.037 0.045 0.072" pos="-0.66 -0.1 0.72"/>

      <!-- Worktop: usable work surface on vention base (1.2m x 0.8m), invisible for clean renders -->
      <site name="worktop" type="box" pos="0 -0.35 0.755" size="0.6 0.4 0.005" rgba="0.2 0.8 0.2 0" group="2"/>

      <!-- Arms start at bottom of rail travel, can raise up to 0.5m -->
      <body name="left_arm_vention_base" pos="-0.330 -0.8480 1.120" quat="0 0 0 1">
        <geom type="box" size="0.1125 0.01 0.1125" mass="18.57" material="red"/>
        <joint name="left_arm_linear_vention" type="slide" axis="0 0 1" range="0 0.5" damping="5000"/>
        <site name="left_arm_attachment_site" size="0.01" pos="0 0.01 0" quat="-0.5 -0.5 -0.5 0.5" rgba="0.5 0.5 0.5 0.3" group="4"/>
      </body>

      <body name="right_arm_vention_base" pos="0.330 -0.8480 1.120" quat="0 0 0 1">
        <geom type="box" size="0.1125 0.01 0.1125" mass="18.57" material="red"/>
        <joint name="right_arm_linear_vention" type="slide" axis="0 0 1" range="0 0.5" damping="5000"/>
        <site name="right_arm_attachment_site" size="0.01" pos="0 0.01 0" quat="-0.5 -0.5 -0.5 0.5" rgba="0.5 0.5 0.5 0.3" group="4"/>
      </body>
    </body>
  </worldbody>

  <actuator>
    <!-- Position-controlled lead screw actuators: 0=bottom, 0.5=top (raised 0.5m) -->
    <position name="left_linear_actuator" joint="left_arm_linear_vention"
              ctrlrange="0 0.5" kp="100000"/>
    <position name="right_linear_actuator" joint="right_arm_linear_vention"
              ctrlrange="0 0.5" kp="100000"/>
  </actuator>

  <keyframe>
    <!-- Ready position: arms at middle of rail (0.25m) -->
    <key name="ready" qpos="0.25 0.25" ctrl="0.25 0.25"/>
  </keyframe>
</mujoco>

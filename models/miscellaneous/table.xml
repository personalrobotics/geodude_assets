<mujoco model="table_178x53x7cm_legs76cm">
  <!--
    Dimensions (meters):
      WIDTH = 1.78, DEPTH = 0.53, THICK = 0.07, LEG_H = 0.76
      Assumed leg cross-section: LEG_W = 0.05 (edit below if desired)

    Derived half-extents (MuJoCo box geoms take half-sizes):
      tabletop half-size: [WIDTH/2, DEPTH/2, THICK/2] = [0.89, 0.265, 0.035]
      leg half-size:     [LEG_W/2, LEG_W/2, LEG_H/2] = [0.025, 0.025, 0.38]

    Placement:
      Table body origin at tabletop center, z = LEG_H + THICK/2 = 0.795
      Legs hang down: leg center z = -(THICK/2 + LEG_H/2) = -0.415
      Leg XY offsets: x = ±(WIDTH/2 - LEG_W/2) = ±0.865, y = ±(DEPTH/2 - LEG_W/2) = ±0.24
  -->

  <option timestep="0.002" gravity="0 0 -9.81"/>
  <compiler angle="degree" coordinate="local"/>

  <default>
    <geom friction="0.8 0.1 0.01" rgba="0.72 0.52 0.30 1" density="700"/>
  </default>

  <worldbody>

    <!-- Table assembly -->
    <body name="table" pos="0 0 0.795">
      <!-- Tabletop -->
      <geom name="tabletop" type="box" size="0.89 0.265 0.04" />

      <!-- Useful site at tabletop center (top surface) -->
      <site name="tabletop_top_center" pos="0 0 0.035" size="0.01" type="sphere" rgba="0.1 0.6 0.1 1"/>

      <!-- Legs (LEG_W = 0.05 m -> half = 0.025) -->
      <!-- Front-right leg (+x, +y) -->
  <geom name="leg_fr" type="box" size="0.025 0.025 0.38" pos="0.865 0.24 -0.415" rgba="0 0 0 1" />
      <!-- Front-left leg (-x, +y) -->
  <geom name="leg_fl" type="box" size="0.025 0.025 0.38" pos="-0.865 0.24 -0.415" rgba="0 0 0 1" />
      <!-- Back-right leg (+x, -y) -->
  <geom name="leg_br" type="box" size="0.025 0.025 0.38" pos="0.865 -0.24 -0.415" rgba="0 0 0 1" />
      <!-- Back-left leg (-x, -y) -->
  <geom name="leg_bl" type="box" size="0.025 0.025 0.38" pos="-0.865 -0.24 -0.415" rgba="0 0 0 1" />
    </body>
  </worldbody>

  <actuator/>
</mujoco>
